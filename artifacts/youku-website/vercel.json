{
  "buildCommand": "cd ../.. && pnpm --filter @workspace/youku-website run build",
  "outputDirectory": "dist/public",
  "installCommand": "cd ../.. && pnpm install",
  "rewrites": [
    { "source": "/play/:id", "destination": "/api/og?id=:id" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
